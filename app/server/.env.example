# REQUIRED — AI plan generation (https://console.anthropic.com/ → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Model used for plan generation (sonnet = fast+cheap, opus = best reasoning)
MODEL=claude-sonnet-4-6

# Enable Claude server-side web search for niche place discovery (true/false).
# Adds cost per search. Set false to generate plans from knowledge only.
USE_WEB_SEARCH=true

# Server port
PORT=8787

# ---- OPTIONAL (not required to run; reserved for venue validation) ----
# GOOGLE_PLACES_API_KEY=
# YELP_API_KEY=
